{
  "rewrites": [
    { "source": "/api/yahoo/:path*", "destination": "https://query1.finance.yahoo.com/v8/finance/:path*" },
    { "source": "/api/gate/:path*", "destination": "https://api.gateio.ws/api/v4/futures/usdt/:path*" },
    { "source": "/api/gate-spot/:path*", "destination": "https://api.gateio.ws/api/v4/spot/:path*" },
    { "source": "/api/binance/:path*", "destination": "https://fapi.binance.com/fapi/v1/:path*" },
    { "source": "/api/binance-spot/:path*", "destination": "https://api.binance.com/api/v3/:path*" },
    { "source": "/api/kraken/:path*", "destination": "https://api.kraken.com/0/public/:path*" },
    { "source": "/api/bybit-spot/:path*", "destination": "https://api.bybit.com/v5/market/:path*" },
    { "source": "/api/vest/:path*", "destination": "https://server-prod.hz.vestmarkets.com/v2/:path*" },
    { "source": "/api/gate-futures/:path*", "destination": "https://api.gateio.ws/api/v4/futures/usdt/:path*" },
    { "source": "/api/bitget-spot/:path*", "destination": "https://api.bitget.com/api/v2/spot/market/:path*" },
    { "source": "/api/bitget-futures/:path*", "destination": "https://api.bitget.com/api/v2/mix/market/:path*" },
    { "source": "/api/dydx/:path*", "destination": "https://indexer.dydx.trade/v4/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
